# Copy to .env and fill in. .env is git-ignored — never commit real keys.

GEMINI_API_KEY=
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=

# Optional model overrides (defaults shown)
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini

# Optional — auto-enables Langfuse tracing (a "trace" link on every result).
# Get keys at https://cloud.langfuse.com (Settings). Use your region's host.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
